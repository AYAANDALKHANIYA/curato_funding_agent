# -------------------------------------------------------
# Curato Funding Intelligence Agent — Environment Config
# -------------------------------------------------------
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env to version control.

# --- Groq API (AI extraction) ---
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- Serper.dev (data enrichment — website & LinkedIn lookup) ---
# Get your token from: https://serper.dev/api-key
SERPER_API_KEY=your_serper_api_key_here

# --- Google Sheets ---
# The ID from your sheet's URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your downloaded service account JSON key file.
# Can be relative (to funding-agent/) or absolute.
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# --- Scheduler ---
# Time (24h HH:MM) to run the pipeline each day.
RUN_TIME=09:00
